{
  "name": "mirv-sim-desktop",
  "version": "1.0.0",
  "description": "MIRV Sim - 洲际导弹多弹头攻击模拟器 (桌面版)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-packager . MIRV-Sim --platform=win32 --arch=x64 --out=dist --overwrite --icon=assets/icon.svg",
    "build:win:portable": "electron-packager . MIRV-Sim --platform=win32 --arch=x64 --out=dist --overwrite --icon=assets/icon.svg",
    "build:mac": "electron-packager . MIRV-Sim --platform=darwin --arch=x64 --out=dist --overwrite --icon=assets/icon.svg",
    "build:linux": "electron-packager . MIRV-Sim --platform=linux --arch=x64 --out=dist --overwrite --icon=assets/icon.svg"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-packager": "^17.1.2"
  }
}
