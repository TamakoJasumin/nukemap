{
  "name": "mirv-sim-desktop",
  "version": "1.0.0",
  "description": "MIRV Sim - 洲际导弹多弹头攻击模拟器 (桌面版)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "powershell -ExecutionPolicy Bypass -File build-win.ps1",
    "package": "powershell -ExecutionPolicy Bypass -Command \"electron-packager.cmd . MIRV-Sim --platform=win32 --arch=x64 --out=dist --overwrite --prune=true --ignore=NukemapApp --ignore=.git --ignore=dist --ignore=installer.iss --ignore=build-win.ps1 --ignore=\u771f\u539f\u751f\u5b89\u5353\""
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-packager": "^17.1.2"
  }
}
